{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud"
      },
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": false
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "distribution": "store",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud",
        "EXPO_PUBLIC_REALTIME_WS": "1",
        "EXPO_IMAGE_NO_AVIF": "1"
      },
      "ios": {
        "image": "macos-sonoma-14.5-xcode-15.4",
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "preInstall": "bash scripts/eas-build-pre-install.sh"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6757429210"
      }
    }
  }
}
