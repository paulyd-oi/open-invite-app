{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud"
      },
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": false
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "production": {
      "distribution": "store",
      "node": "18.20.2",
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "npm",
        "EXPO_USE_NPM": "1",
        "EXPO_NO_BUN": "1",
        "NPM_CONFIG_INCLUDE": "dev",
        "EXPO_PUBLIC_API_URL": "https://api.openinvite.cloud",
        "EXPO_PUBLIC_REALTIME_WS": "1",
        "EXPO_IMAGE_NO_AVIF": "1",
        "SENTRY_AUTH_TOKEN": "TODO_GET_FROM_SENTRY_SETTINGS_AUTH_TOKENS"
      },
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6757429210"
      }
    }
  }
}
